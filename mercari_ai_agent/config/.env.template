# 环境变量模板文件
# Mercari AI Agent Environment Variables Template
# 
# 说明：
# 1. 复制此文件为 .env 并填入实际值
# 2. 不要将包含真实密钥的 .env 文件提交到版本控制
# 3. 所有敏感信息都应该通过环境变量配置

# =============================================================================
# 基础配置
# =============================================================================

# 运行环境 (development/production/testing)
ENVIRONMENT=development

# 调试模式 (true/false)
DEBUG=true

# =============================================================================
# LLM API配置
# =============================================================================

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Azure OpenAI配置
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_API_VERSION=2023-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4

# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mercari_agent
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DATABASE=mercari_agent

# SQLite配置
SQLITE_PATH=./data/mercari_agent.db

# =============================================================================
# 缓存配置
# =============================================================================

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# =============================================================================
# API配置
# =============================================================================

# API服务器配置
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_very_secret_key_here_change_in_production

# 允许的来源 (CORS)
ALLOWED_ORIGINS=*

# JWT配置
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# 第三方服务配置
# =============================================================================

# 代理配置
PROXY_HTTP=
PROXY_HTTPS=
PROXY_USER=
PROXY_PASSWORD=

# 邮件配置
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 短信配置
SMS_API_KEY=
SMS_API_SECRET=

# =============================================================================
# 监控和日志配置
# =============================================================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/mercari_agent.log

# 性能监控
ENABLE_PERFORMANCE_MONITORING=true
SLOW_QUERY_THRESHOLD=1.0

# 错误追踪
SENTRY_DSN=

# =============================================================================
# 安全配置
# =============================================================================

# 加密密钥
ENCRYPTION_KEY=your_encryption_key_here

# 会话配置
SESSION_SECRET=your_session_secret_here
SESSION_TIMEOUT=3600

# 安全头配置
SECURITY_HEADERS_ENABLED=true

# =============================================================================
# 特性开关
# =============================================================================

# 高级分析功能
ENABLE_ADVANCED_ANALYSIS=true

# 市场趋势分析
ENABLE_MARKET_TREND=true

# 价格预测
ENABLE_PRICE_PREDICTION=true

# 卖家验证
ENABLE_SELLER_VERIFICATION=true

# 图像分析
ENABLE_IMAGE_ANALYSIS=false

# 推荐学习
ENABLE_RECOMMENDATION_LEARNING=true

# =============================================================================
# 性能配置
# =============================================================================

# 工作线程数
MAX_WORKERS=4

# 内存限制 (字节)
MAX_MEMORY_USAGE=1073741824

# 并发请求数
MAX_CONCURRENT_REQUESTS=10

# 请求超时 (秒)
REQUEST_TIMEOUT=30

# =============================================================================
# 开发配置
# =============================================================================

# 开发模式配置
DEV_RELOAD=true
DEV_DEBUG_SQL=false
DEV_MOCK_EXTERNAL_API=false

# 测试配置
TEST_DATABASE_URL=sqlite:///test.db
TEST_CACHE_BACKEND=memory
TEST_SKIP_SLOW_TESTS=false

# =============================================================================
# 部署配置
# =============================================================================

# 容器配置
CONTAINER_NAME=mercari-ai-agent
CONTAINER_PORT=8000
CONTAINER_MEMORY_LIMIT=2g

# 负载均衡配置
LOAD_BALANCER_URL=
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# CDN配置
CDN_URL=
CDN_API_KEY=
CDN_SECRET_KEY=