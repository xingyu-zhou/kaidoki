{
  "environment": "development",
  "debug": true,
  "database": {
    "sqlite_path": "./data/dev_mercari_agent.db"
  },
  "llm": {
    "max_tokens": 4000,
    "temperature": 0.7,
    "timeout": 30
  },
  "scraping": {
    "max_retries": 3,
    "timeout": 30,
    "delay_range": [1, 3],
    "max_pages": 3,
    "max_products": 30,
    "use_cache": true,
    "cache_ttl": 180
  },
  "logging": {
    "level": "DEBUG",
    "log_dir": "./logs/dev"
  },
  "api": {
    "host": "127.0.0.1",
    "port": 8000,
    "debug": true,
    "rate_limit": 200
  }
}